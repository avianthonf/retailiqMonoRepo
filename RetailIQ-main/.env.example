# RetailIQ Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development
ENVIRONMENT=development
APP_VERSION=1.0.0

# ── Database (Railway provides DATABASE_URL automatically) ───────────────────
DATABASE_URL=postgresql://retailiq:retailiq@localhost:5432/retailiq

# ── Redis (Railway provides REDIS_URL automatically) ────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRES_HOURS=24
JWT_REFRESH_EXPIRES_DAYS=30

# ── Email (optional — set EMAIL_ENABLED=true to send real OTPs) ──────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@retailiq.com

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=200/hour

# ── Frontend URL (used in password reset emails) ─────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Postgres credentials (used by docker-compose) ────────────────────────────
POSTGRES_USER=retailiq
POSTGRES_PASSWORD=retailiq
POSTGRES_DB=retailiq
